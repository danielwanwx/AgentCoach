# === AgentCoach Configuration ===

# Option A: Local Gemma 4 via Ollama (free, recommended)
LLM_PROVIDER=ollama
LLM_API_KEY=not-needed
# LLM_MODEL=gemma4:e4b          # 9.6GB, good for Mac Mini
# LLM_MODEL=gemma4:31b          # 20GB, best quality

# Option B: MiniMax API (cloud)
# LLM_PROVIDER=minimax
# LLM_API_KEY=your-minimax-key

# Option C: DeepSeek API (cloud)
# LLM_PROVIDER=deepseek
# LLM_API_KEY=your-deepseek-key

# TTS (text-to-speech)
TTS_ENGINE=macos                  # macos | qwen | vibevoice | none
# TTS_VOICE=Samantha             # macOS voice name
# TTS_DEVICE=mps                 # for qwen/vibevoice: mps (Mac), cuda (NVIDIA)

# Optional web TTS: if CARTESIA_API_KEY is set, the browser session will
# use server-side Cartesia audio automatically and fall back to browser TTS.
# AGENTCOACH_TTS_PROVIDER=cartesia
# CARTESIA_API_KEY=your-cartesia-key
# CARTESIA_MODEL_ID=sonic-3
# CARTESIA_VOICE_ID=f786b574-daa5-4673-aa0c-cbe3e8534c02

# Optional local natural TTS for web sessions. Use a voice sample only when
# you own it or have explicit permission to clone that voice.
# AGENTCOACH_TTS_PROVIDER=vibevoice
# VIBEVOICE_MODEL_PATH=microsoft/VibeVoice-1.5B
# VIBEVOICE_DEVICE=mps
# VIBEVOICE_VOICE_SAMPLE=/absolute/path/to/authorized-voice.wav

# Optional: use smaller local model for lightweight tasks
# LOCAL_LLM_SMALL=ollama-small   # routes compression/rerank to gemma4:e4b
